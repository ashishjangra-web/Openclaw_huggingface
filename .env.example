# -------------------------------------------------------------------
# Local-only convenience file.
# Do NOT commit real secrets to git.
# Hugging Face Spaces: set these in Settings -> Variables & secrets.
# -------------------------------------------------------------------

# --- GitHub memory sync (required for pushing memory) ---
# Fine-grained PAT with Contents: Read and write for your memory repo.
HF_GITHUB_TOKEN=

# Memory repo URL (must be https)
GIT_MEMORY_REPO=

# Could be Fictional (Make JARVIS commit your github)
GIT_USER_NAME=
GIT_USER_EMAIL=

# Provider (google, openai, anthropic, etc.)
MODEL_PROVIDER=google
# Model Name (e.g. google/gemini-3.1-flash-lite-preview)
MODEL_NAME=google/gemini-3.1-flash-lite-preview

# Fallback Model (optional) - Used if the primary model fails
MODEL_FALLBACK=openrouter/google/gemma-4-31b-it

# --- Model key rotation (primary provider) ---
MODEL_KEY_1=
MODEL_KEY_2=
MODEL_KEY_3=
MODEL_KEY_4=

# --- Telegram Bot Configuration (Optional) ---
# Token from @BotFather for your bot
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram ID for private access
TELEGRAM_ALLOWED_USER_ID=

# --- Optional: OpenRouter (needed for Gemma fallback) ---
OPENROUTER_API_KEY=

# --- Optional overrides ---
# OPENCLAW_WORKSPACE=/workspace

